# Rolplay Multi-Tenant Bridge — required environment variables
# Copy to a real .env / set on the container. NEVER commit actual values.

# ── Sanfer ──────────────────────────────────────────────────────────────────
SANFER_DB_HOST=
SANFER_DB_PORT=3306
SANFER_DB_NAME=
SANFER_DB_USER=
SANFER_DB_PASS=
SANFER_DB_COLL=utf8mb4

SANFER_ORG_DB_HOST=
SANFER_ORG_DB_PORT=3306
SANFER_ORG_DB_NAME=
SANFER_ORG_DB_USER=
SANFER_ORG_DB_PASS=

SANFER_OFF_DB_HOST=
SANFER_OFF_DB_PORT=3306
SANFER_OFF_DB_NAME=
SANFER_OFF_DB_USER=
SANFER_OFF_DB_PASS=

# ── Apotex ──────────────────────────────────────────────────────────────────
APOTEX_DB_HOST=
APOTEX_DB_NAME=
APOTEX_DB_USER=
APOTEX_DB_PASS=

APOTEX_DB2_HOST=
APOTEX_DB2_NAME=
APOTEX_DB2_USER=
APOTEX_DB2_PASS=
